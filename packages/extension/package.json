{
  "name": "@lenses/extension",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "bun run build.ts",
    "build:contest": "bun run build.ts --production --contest",
    "build:production": "bun run build.ts --production",
    "check:contest": "bun run check-production-artifact.ts dist --contest",
    "check:production": "bun run check-production-artifact.ts dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "bun run build.ts --watch"
  },
  "dependencies": {
    "@lenses/backend": "workspace:*",
    "@lenses/shared": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "convex": "^1.30.0",
    "defuddle": "^0.6.6",
    "dexie": "^4.4.3",
    "effect": "^3.19.0",
    "lucide-react": "^1.21.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.7"
  }
}
